{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-knowledge-mcp.sh", "timeout": 30000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-plugins.sh", "timeout": 10000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-permissions.sh", "timeout": 10000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-playwright-mcp.sh", "timeout": 30000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-claude-monitor.sh", "timeout": 30000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-plan-viewer.sh", "timeout": 5000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-rtk.sh", "timeout": 15000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cartography.sh", "timeout": 15000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh SessionStart", "timeout": 10000 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/block-protected-push.sh", "if": "Bash(git push *)" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/block-no-verify.sh", "if": "Bash(git *--no-verify*)" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/block-secret-commits.sh", "if": "Bash(git add *)" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/block-claude-identity.sh", "if": "Bash(git commit *)" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/block-claude-identity.sh", "if": "Bash(gh pr create*)" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/auto-compress-output.sh", "timeout": 30000 }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/warn-secret-files.sh", "timeout": 3000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/block-wrong-plan-dir.sh", "timeout": 3000 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/claude-monitor/claude-session-track.sh PreToolUse" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh PostToolUse 'Write|Edit'", "timeout": 3000 }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh PostToolUse EnterPlanMode", "timeout": 5000 }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/restructure-plan.py", "timeout": 30000 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh PostToolUse ExitPlanMode", "timeout": 10000 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh PostToolUse Bash", "if": "Bash(gh pr create*)", "async": false },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/track-test-failures.sh", "timeout": 3000 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/auto-update-codemaps.sh", "if": "Bash(git commit*)", "timeout": 60000 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/claude-monitor/claude-session-track.sh PostToolUse" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh SubagentStop", "timeout": 3000 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/claude-monitor/claude-session-track.sh Stop" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh Stop", "timeout": 5000 }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh PostCompact", "timeout": 5000 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/workflow-hook.sh UserPromptSubmit", "timeout": 15000 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/claude-monitor/claude-session-track.sh UserPromptSubmit" }
        ]
      }
    ]
  }
}
